{
  "version": 1,
  "default_profile": "doc_only",
  "profiles": {
    "doc_only": {
      "tier": 1,
      "auto_merge_eligible": true,
      "title_keywords": ["README", "문서", "RULES", "AGENTS", "가이드", "정리"],
      "allowed_path_prefixes": [
        "README",
        "docs/project/RULES.md",
        "AGENTS.md",
        "docs/project/TASKS.md",
        "docs/",
        "docs/project/done_tasks.md",
        "docs/project/failed_tasks.md",
        "docs/project/blocked_tasks.md"
      ]
    },
    "script_safe": {
      "tier": 2,
      "auto_merge_eligible": true,
      "title_keywords": ["스크립트", "script", "파서", "selector", "수집", "gate", "체크"],
      "allowed_path_prefixes": ["scripts/", "auto_dev/"]
    },
    "test_fix": {
      "tier": 2,
      "auto_merge_eligible": true,
      "title_keywords": ["테스트", "pytest", "회귀", "fixture", "replay"],
      "allowed_path_prefixes": ["tests/"]
    },
    "config_data": {
      "tier": 2,
      "auto_merge_eligible": false,
      "title_keywords": ["sites.json", "groups.json", "수신자", "사이트 추가", "설정"],
      "allowed_path_prefixes": ["config/"]
    },
    "core_logic": {
      "tier": 0,
      "auto_merge_eligible": false,
      "blocked": true,
      "title_keywords": ["monitor.py", "streamlit", "발송 로직", "SMTP"],
      "allowed_path_prefixes": []
    },
    "accuracy": {
      "tier": 3,
      "auto_merge_eligible": false,
      "title_keywords": ["정확도", "accuracy", "recall", "오탐", "누락", "region_FP"],
      "allowed_path_prefixes": [
        "mail_core/matching/",
        "data/golden/",
        "scripts/accuracy_"
      ]
    }
  }
}
