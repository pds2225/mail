{
  "version": 2,
  "functions": {
    "api/health.py": {
      "runtime": "vercel-python@3.0"
    },
    "api/index.py": {
      "runtime": "vercel-python@3.0"
    }
  },
  "routes": [
    {
      "src": "/api/health",
      "dest": "api/health.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/",
      "dest": "/auto_mail_web.html"
    }
  ]
}
