{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@3.0"
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "auto_mail_web.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/",
      "dest": "auto_mail_web.html"
    }
  ]
}

