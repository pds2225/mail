# D:\mail\.env — 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# 절대 Git에 올리지 마세요 (.gitignore 처리됨)

# --- Google Sheets (dry-run false / 실제 기록 시 필수) ---
# 스프레드시트 URL: https://docs.google.com/spreadsheets/d/여기가_ID/edit
GOOGLE_SHEET_ID=

# 서비스 계정 JSON 파일 경로 (권장)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=D:\mail\secrets\google_service_account.json

# 또는 JSON 파일 경로/내용 (PATH와 둘 중 하나만 써도 됨)
# GOOGLE_SERVICE_ACCOUNT_JSON=D:\mail\secrets\google_service_account.json

# --- CLOVA OCR (실제 OCR 시 둘 다 필수, 없으면 Mock 모드) ---
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=

# --- 선택: 수신자/기업 설정(PII)을 시크릿으로 주입 ---
# groups.json / companies.json 에는 수신자 이메일 등 PII 가 들어갈 수 있다.
# 레포에 커밋하지 않으려면 아래 환경변수로 주입한다(값이 없으면 레포의 파일로 폴백).
# 값 형식: 인라인 JSON('['/'{' 로 시작) 또는 JSON 파일 경로 — 둘 다 지원.
#   예1(인라인): MAIL_GROUPS_JSON=[{"id":"g1","active":true, ...}]
#   예2(경로):   MAIL_GROUPS_JSON=D:\mail\secrets\groups.json
# MAIL_GROUPS_JSON=
# MAIL_COMPANIES_JSON=

# --- 선택: inbox/보고서 경로 변경 ---
# CUSTOMER_INTAKE_INBOX=D:\customer_intake_inbox
# CUSTOMER_INTAKE_DONE=D:\customer_intake_done
# CUSTOMER_INTAKE_FAILED=D:\customer_intake_failed
# CUSTOMER_INTAKE_REPORTS=D:\customer_intake_reports

# --- 소진공 정책자금 점검 (loan/semas) ---
SEMAS_LOAN_URL=https://ols.semas.or.kr/ols/man/SMAN051M/page.do
MAIL_TO=ekth3691@gmail.com  # pragma: allowlist secret
ALLOW_SEND_EMAIL=false
DEFAULT_RUN_MODE=dry-run
LOOKBACK_DAYS=3

# 실제 메일 발송은 기존 mail 레포의 메일 변수명을 그대로 사용합니다.
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
