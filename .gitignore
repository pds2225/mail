# 환경변수·인증 (절대 올리지 말 것)
.env
.env.*
!.env.example
*.env.txt
secrets/
!secrets/README.md

# 실행 중 생성되는 파일
# 아래 3개 상태 파일은 GitHub Actions의 실행 간 멱등성 유지를 위해 예외적으로 추적한다.
# var/state/seen_ids.json
# var/state/delivery_state.json
# var/outbox/delivery_outbox.enc
monitor.run.lock
*.lock
state_backups/
var/state/coverage_baseline.json
var/state/state_backups/
var/outbox/state_backups/
var/logs/*
!var/logs/.gitkeep
test_results.json
var/reports/loan/semas_loan_scan.md
var/reports/loan/semas_seen_notices.json
# 검수 결과 파일 (런타임 생성, 직접 배포하지 않음)
var/reports/review/*_review.md
var/reports/review/*_send.csv
var/reports/review/*_mail_draft.txt
# digest 품질 계측 산출물 (런타임 생성)
workspace/digest_quality_*.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 가상환경
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Vercel / Node
.vercel/
node_modules/

.claude/

# Local diagnostic outputs
config/groups.backup.*.json
var/reports/site_diagnostic_*.json
var/reports/site_diagnostic_*.md
var/reports/site_parse_diag_*.json
var/reports/autofill_recs.json
var/reports/diag_classified.json
.omc/
.bkit/
var/reports/company_match/
RESUME.md
var/raw/*
!var/raw/.gitkeep

# 임시 진단·실험 스크립트 (루트 한정 — 패키지 __init__.py 는 제외)
/_*.py
!/__init__.py
/scratch_*.txt

# 수동 백업본 (groups.json.bak2, sites.json.bak_genfix, seen_ids.json.fullbak …)
*.bak
*.bak[0-9]
*.bak_*
*.fullbak
*.datebak

# 런타임 로그 (`var/logs/*.md`는 위에서 처리)
var/logs/*.log
var/logs/*.json

# 공고 첨부 다운로드 (scripts/download_kstartup_targets.py 로 재생성 가능)
downloads/

# 빌드/익스포트 산출물
*.zip
